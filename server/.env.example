PORT=5000
MONGODB_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
OPENAI_API_KEY=your_api_key

# Optional API provider overrides (e.g. for Groq or OpenRouter)
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
# WHISPER_MODEL=whisper-large-v3

# Frontend client URL (used for CORS and OpenRouter Referer)
CLIENT_URL=http://localhost:5173

# Optional: Run backend with local in-memory DB if true (requires mongodb-memory-server dependency)
USE_IN_MEMORY_DB=0

# DNS servers fallback for Windows mongodb+srv SRV lookup resolution issues
# DNS_SERVERS=8.8.8.8,1.1.1.1
# MONGO_DNS_USE_SYSTEM=0
